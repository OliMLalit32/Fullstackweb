<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ApnaGhar – Student-Friendly Rentals</title>
    <link rel="icon" type="image/png" href="/images/house.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/rating.css">
</head>
<body>
    <%- include("../includes/navbar.ejs") %>

    <div id="toast-container" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;"></div>

    <div class="flash-container">
        <%- include("../includes/flash.ejs") %>
    </div>

    <main>
        <%- body %>
    </main>

    <%- include("../includes/footer.ejs") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/script.js"></script>

    <% if (typeof currUser !== 'undefined' && currUser) { %>
    <script>
        const socket = io();
        socket.emit('join', '<%= currUser._id %>');
        socket.on('notification', (data) => {
            const badge = document.getElementById('notif-badge');
            if (badge) {
                badge.classList.remove('d-none');
                const count = parseInt(badge.textContent || '0') + 1;
                badge.textContent = count;
            }
            showToastNotification(data.title, data.message, data.type);
        });

        function showToastNotification(title, message, type) {
            const toastContainer = document.getElementById('toast-container');
            if (!toastContainer) return;
            const id = 'toast-' + Date.now();
            const iconMap = {
                booking_confirmed: 'fa-check-circle text-success',
                booking_rejected: 'fa-times-circle text-danger',
                booking_request: 'fa-bell text-warning',
                booking_cancelled: 'fa-ban text-secondary',
                payment_confirmed: 'fa-credit-card text-success',
            };
            const icon = iconMap[type] || 'fa-bell text-primary';
            const html = `
            <div id="${id}" class="toast align-items-center border-0 shadow-lg mb-2" role="alert" style="min-width:300px;background:white;">
              <div class="toast-header border-0" style="background:#f8f5ff;">
                <i class="fa-solid ${icon} me-2"></i>
                <strong class="me-auto" style="color:#7c3aed;">${title}</strong>
                <small class="text-muted">Just now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
              </div>
              <div class="toast-body text-muted">${message}</div>
            </div>`;
            toastContainer.insertAdjacentHTML('beforeend', html);
            const toastEl = document.getElementById(id);
            const bsToast = new bootstrap.Toast(toastEl, { delay: 6000 });
            bsToast.show();
            toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
        }
    </script>
    <% } %>
</body>
</html>
