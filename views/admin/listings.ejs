<% layout("/layouts/boilerplate") %>

<div class="dashboard-page">
  <div class="container-fluid py-4 px-4">
    <div class="dashboard-header mb-4">
      <div>
        <h3><i class="fa-solid fa-home me-2 text-purple"></i>All Listings</h3>
        <p class="text-muted mb-0">Manage all property listings on the platform</p>
      </div>
      <a href="/admin/dashboard" class="btn-cancel">← Dashboard</a>
    </div>

    <div class="dashboard-section">
      <% if (listings.length === 0) { %>
        <div class="empty-state text-center py-5">
          <i class="fa-solid fa-home empty-icon mb-3"></i>
          <h5>No listings yet</h5>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Owner</th>
                <th>Location</th>
                <th>Price/night</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% for (let l of listings) { %>
                <tr>
                  <td><img src="<%= l.image.url %>" alt="" class="admin-thumb"></td>
                  <td class="fw-600"><%= l.title %></td>
                  <td><%= l.owner ? (l.owner.fullName || l.owner.username) : '—' %></td>
                  <td><%= l.location %>, <%= l.country %></td>
                  <td class="text-purple fw-600">₹<%= l.price.toLocaleString("en-IN") %></td>
                  <td>
                    <div class="d-flex gap-2">
                      <a href="/listings/<%= l._id %>" class="btn-icon-sm" title="View"><i class="fa-solid fa-eye"></i></a>
                      <a href="/listings/<%= l._id %>/edit" class="btn-icon-sm" title="Edit"><i class="fa-solid fa-pen"></i></a>
                      <form method="POST" action="/admin/listings/<%= l._id %>?_method=DELETE" onsubmit="return confirm('Delete this listing?')">
                        <button class="btn-icon-sm btn-icon-danger" title="Delete"><i class="fa-solid fa-trash"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
