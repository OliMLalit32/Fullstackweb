<% layout("/layouts/boilerplate") %>

<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <h3><i class="fa-solid fa-plus-circle me-2 text-purple"></i>Add a New Listing</h3>
      <p class="text-muted mb-0">Fill in the details to list your property on ApnaGhar.</p>
    </div>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="row">
        <div class="col-12 mb-3">
          <label class="form-label-modern">Property Title *</label>
          <div class="input-modern">
            <i class="fa-solid fa-home input-icon"></i>
            <input name="listing[title]" type="text" class="form-control-modern" placeholder="e.g. Cozy Room Near IIT Delhi" required>
          </div>
          <div class="valid-feedback">Looks good!</div>
        </div>

        <div class="col-12 mb-3">
          <label class="form-label-modern">Description *</label>
          <textarea name="listing[description]" class="form-control-modern" rows="4" placeholder="Describe your property, amenities, rules..." required></textarea>
          <div class="invalid-feedback">Please enter a description.</div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label-modern">Price per Night (₹) *</label>
          <div class="input-modern">
            <i class="fa-solid fa-indian-rupee-sign input-icon"></i>
            <input name="listing[price]" type="number" class="form-control-modern" placeholder="e.g. 2500" min="0" required>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label-modern">Country *</label>
          <div class="input-modern">
            <i class="fa-solid fa-globe input-icon"></i>
            <input name="listing[country]" type="text" class="form-control-modern" placeholder="India" required>
          </div>
        </div>

        <div class="col-12 mb-3">
          <label class="form-label-modern">Location / Address *</label>
          <div class="input-modern">
            <i class="fa-solid fa-location-dot input-icon"></i>
            <input name="listing[location]" type="text" class="form-control-modern" placeholder="e.g. Hauz Khas, New Delhi" required>
          </div>
        </div>

        <div class="col-12 mb-4">
          <label class="form-label-modern">Property Image *</label>
          <div class="file-upload-area" onclick="document.getElementById('imgInput').click()">
            <i class="fa-solid fa-cloud-arrow-up upload-icon mb-2"></i>
            <p class="mb-0">Click to upload image</p>
            <small class="text-muted">JPEG, PNG supported</small>
            <input id="imgInput" name="listing[image]" type="file" class="d-none" accept="image/*" required onchange="previewImg(this)">
          </div>
          <div id="img-preview" class="mt-2 d-none">
            <img id="preview-img" src="" alt="Preview" style="max-height:180px;border-radius:12px;object-fit:cover;">
          </div>
        </div>

        <div class="col-12 mb-4">
          <label class="form-label-modern">Features & Amenities</label>
          <div class="features-grid">
            <% const allFeatures = ["Wifi","Furnished","Private Kitchen","Attached Bathroom","Single Room","Double Sharing","Independent","Within 1km"]; %>
            <% const featureIcons = {"Wifi":"fa-wifi","Furnished":"fa-couch","Private Kitchen":"fa-kitchen-set","Attached Bathroom":"fa-bath","Single Room":"fa-bed","Double Sharing":"fa-users","Independent":"fa-house-user","Within 1km":"fa-location-dot"}; %>
            <% for (let feature of allFeatures) { %>
              <label class="feature-checkbox-label">
                <input type="checkbox" name="listing[features][]" value="<%= feature %>" class="feature-checkbox">
                <div class="feature-box">
                  <i class="fa-solid <%= featureIcons[feature] %>"></i>
                  <span><%= feature %></span>
                </div>
              </label>
            <% } %>
          </div>
        </div>

        <div class="col-12">
          <button type="submit" class="btn-auth-primary">
            <i class="fa-solid fa-plus me-2"></i>Create Listing
          </button>
          <a href="/listings" class="btn-cancel ms-3">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
function previewImg(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('preview-img').src = e.target.result;
      document.getElementById('img-preview').classList.remove('d-none');
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>
