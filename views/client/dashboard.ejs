<% layout("/layouts/boilerplate") %>

<div class="dashboard-page">
  <div class="container py-4">
    <div class="dashboard-header mb-4">
      <div>
        <h3><i class="fa-solid fa-user me-2 text-purple"></i>My Dashboard</h3>
        <p class="text-muted mb-0">Welcome, <%= currUser.fullName || currUser.username %>!</p>
      </div>
      <a href="/listings" class="btn-book-now">
        <i class="fa-solid fa-search me-2"></i>Find Property
      </a>
    </div>

    <div class="stats-grid mb-5">
      <div class="stat-card">
        <div class="stat-icon" style="background:#f0e9ff;color:#7c3aed;"><i class="fa-solid fa-calendar-check"></i></div>
        <div class="stat-value"><%= bookings.length %></div>
        <div class="stat-label">Total Bookings</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa-solid fa-check-circle"></i></div>
        <div class="stat-value"><%= bookings.filter(b => b.status === 'confirmed').length %></div>
        <div class="stat-label">Confirmed</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#fef3c7;color:#d97706;"><i class="fa-solid fa-clock"></i></div>
        <div class="stat-value"><%= bookings.filter(b => b.status === 'pending').length %></div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;color:#dc2626;"><i class="fa-solid fa-ban"></i></div>
        <div class="stat-value"><%= bookings.filter(b => b.status === 'cancelled' || b.status === 'rejected').length %></div>
        <div class="stat-label">Cancelled</div>
      </div>
    </div>

    <div class="dashboard-section">
      <h5 class="section-title mb-3"><i class="fa-solid fa-list me-2"></i>My Bookings</h5>
      <% if (bookings.length === 0) { %>
        <div class="empty-state text-center py-5">
          <i class="fa-solid fa-calendar-xmark empty-icon mb-3"></i>
          <h5>No bookings yet</h5>
          <a href="/listings" class="btn-primary-pill mt-2">Browse Listings</a>
        </div>
      <% } else { %>
        <div class="bookings-list">
          <% for (let b of bookings) { %>
            <div class="booking-list-card">
              <div class="booking-list-img">
                <% if (b.listing && b.listing.image) { %>
                  <img src="<%= b.listing.image.url %>" alt="">
                <% } else { %>
                  <div class="no-img-placeholder"><i class="fa-solid fa-home"></i></div>
                <% } %>
              </div>
              <div class="booking-list-info">
                <div class="d-flex justify-content-between flex-wrap gap-2">
                  <h6 class="mb-1 fw-700"><%= b.listing ? b.listing.title : 'Listing Removed' %></h6>
                  <span class="status-badge status-<%= b.status %>"><%= b.status %></span>
                </div>
                <div class="booking-dates mt-1">
                  <span><%= new Date(b.checkIn).toDateString() %></span>
                  <i class="fa-solid fa-arrow-right mx-2 text-muted"></i>
                  <span><%= new Date(b.checkOut).toDateString() %></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-2 flex-wrap gap-2">
                  <span class="fw-700 text-purple">₹<%= b.totalAmount.toLocaleString("en-IN") %></span>
                  <a href="/bookings/<%= b._id %>/confirmation" class="btn-view-booking">View Details</a>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
