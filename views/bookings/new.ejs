<% layout("/layouts/boilerplate") %>

<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <div class="d-flex align-items-center gap-3 mb-3">
        <img src="<%= listing.image.url %>" alt="" style="width:70px;height:70px;border-radius:12px;object-fit:cover;">
        <div>
          <h4 class="mb-1"><%= listing.title %></h4>
          <span class="text-muted"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></span>
        </div>
      </div>
      <div class="price-highlight">
        <span class="fw-700 fs-5 text-purple">₹<%= listing.price.toLocaleString("en-IN") %></span>
        <span class="text-muted"> / night</span>
      </div>
    </div>

    <h5 class="mb-4"><i class="fa-solid fa-calendar-plus me-2 text-purple"></i>Select Your Dates</h5>

    <form method="POST" action="/listings/<%= listing._id %>/book" id="booking-form" novalidate class="needs-validation">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label-modern">Check-In Date *</label>
          <div class="input-modern">
            <i class="fa-solid fa-calendar-day input-icon"></i>
            <input type="date" name="checkIn" id="checkIn" class="form-control-modern" required min="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label-modern">Check-Out Date *</label>
          <div class="input-modern">
            <i class="fa-solid fa-calendar-check input-icon"></i>
            <input type="date" name="checkOut" id="checkOut" class="form-control-modern" required>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label-modern">Number of Guests</label>
          <div class="input-modern">
            <i class="fa-solid fa-users input-icon"></i>
            <input type="number" name="guests" class="form-control-modern" value="1" min="1" max="10">
          </div>
        </div>

        <div class="col-12 mb-4">
          <label class="form-label-modern">Special Requests (Optional)</label>
          <textarea name="specialRequests" class="form-control-modern" rows="3" placeholder="Any special requirements or notes for the owner..."></textarea>
        </div>

        <div class="col-12 mb-4">
          <div id="price-summary" class="price-summary-box d-none">
            <div class="d-flex justify-content-between mb-2">
              <span>₹<%= listing.price.toLocaleString("en-IN") %> × <span id="nights-count">0</span> nights</span>
              <span id="subtotal">₹0</span>
            </div>
            <div class="d-flex justify-content-between fw-700 fs-5">
              <span>Total</span>
              <span id="total-amount" class="text-purple">₹0</span>
            </div>
          </div>
        </div>

        <div id="availability-msg" class="col-12 mb-3"></div>

        <div class="col-12">
          <button type="submit" class="btn-book-now w-100" id="submit-btn">
            <i class="fa-solid fa-arrow-right me-2"></i>Continue to Confirmation
          </button>
          <a href="/listings/<%= listing._id %>" class="btn-cancel d-block text-center mt-3">Back to Listing</a>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
const pricePerNight = <%= listing.price %>;
const listingId = '<%= listing._id %>';
const bookedDates = <%- JSON.stringify(bookedDates) %>;

const checkInEl = document.getElementById('checkIn');
const checkOutEl = document.getElementById('checkOut');

function updatePriceSummary() {
  const ci = new Date(checkInEl.value);
  const co = new Date(checkOutEl.value);
  if (!checkInEl.value || !checkOutEl.value || ci >= co) {
    document.getElementById('price-summary').classList.add('d-none');
    return;
  }
  const nights = Math.ceil((co - ci) / (1000 * 60 * 60 * 24));
  const total = nights * pricePerNight;
  document.getElementById('nights-count').textContent = nights;
  document.getElementById('subtotal').textContent = '₹' + total.toLocaleString('en-IN');
  document.getElementById('total-amount').textContent = '₹' + total.toLocaleString('en-IN');
  document.getElementById('price-summary').classList.remove('d-none');
  checkAvailability(ci, co);
}

function checkAvailability(ci, co) {
  const msgEl = document.getElementById('availability-msg');
  const conflict = bookedDates.some(b => {
    const bIn = new Date(b.checkIn);
    const bOut = new Date(b.checkOut);
    return ci < bOut && co > bIn;
  });
  if (conflict) {
    msgEl.innerHTML = '<div class="alert-unavailable"><i class="fa-solid fa-circle-xmark me-2"></i>These dates are not available. Please choose different dates.</div>';
    document.getElementById('submit-btn').disabled = true;
  } else {
    msgEl.innerHTML = '<div class="alert-available"><i class="fa-solid fa-circle-check me-2"></i>Dates are available!</div>';
    document.getElementById('submit-btn').disabled = false;
  }
}

checkInEl.addEventListener('change', () => {
  checkOutEl.min = checkInEl.value;
  updatePriceSummary();
});
checkOutEl.addEventListener('change', updatePriceSummary);
</script>
