<% if (typeof success !== 'undefined' && success.length) { %>
  <div class="flash-alert flash-success d-flex align-items-center gap-2" role="alert">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
    <button type="button" class="btn-close ms-auto" onclick="this.parentElement.remove()"></button>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error.length) { %>
  <div class="flash-alert flash-error d-flex align-items-center gap-2" role="alert">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
    <button type="button" class="btn-close ms-auto" onclick="this.parentElement.remove()"></button>
  </div>
<% } %>
