<nav class="navbar navbar-expand-lg sticky-top" id="main-navbar">
  <div class="container-fluid px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/listings">
      <div class="brand-icon">
        <i class="fa-solid fa-house-chimney"></i>
      </div>
      <span class="brand-name">ApnaGhar</span>
    </a>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <div class="navbar-nav mx-auto">
        <form class="search-form d-flex align-items-center" action="/listings" method="GET">
          <div class="search-pill">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input class="search-input" type="search" name="search" placeholder="Search city, country...">
            <button class="search-btn" type="submit">Search</button>
          </div>
        </form>
      </div>

      <div class="navbar-nav ms-auto align-items-center gap-2">
        <% if (typeof currUser === 'undefined' || !currUser) { %>
          <a class="nav-link-pill" href="/signup?role=client">
            <i class="fa-solid fa-user-plus me-1"></i>Sign Up
          </a>
          <a class="nav-btn-primary" href="/login">
            <i class="fa-solid fa-right-to-bracket me-1"></i>Log In
          </a>
        <% } else { %>
          <% if (currUser.role === 'owner' || currUser.role === 'admin') { %>
            <a class="nav-link-pill" href="/listings/new">
              <i class="fa-solid fa-plus me-1"></i>Add Listing
            </a>
          <% } %>

          <a href="/notifications" class="nav-icon-btn position-relative" title="Notifications">
            <i class="fa-solid fa-bell"></i>
            <span id="notif-badge" class="notif-badge d-none">0</span>
          </a>

          <div class="dropdown">
            <button class="user-menu-btn dropdown-toggle" data-bs-toggle="dropdown">
              <div class="user-avatar">
                <%= (currUser.fullName || currUser.username).charAt(0).toUpperCase() %>
              </div>
              <span class="user-name d-none d-md-inline"><%= currUser.fullName || currUser.username %></span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end user-dropdown">
              <li class="dropdown-header">
                <div class="d-flex align-items-center gap-2 py-1">
                  <div class="user-avatar-sm"><%= (currUser.fullName || currUser.username).charAt(0).toUpperCase() %></div>
                  <div>
                    <div class="fw-600"><%= currUser.fullName || currUser.username %></div>
                    <div class="text-muted small role-badge-sm
                      <%= currUser.role === 'admin' ? 'role-admin' : currUser.role === 'owner' ? 'role-owner' : 'role-client' %>">
                      <%= currUser.role.charAt(0).toUpperCase() + currUser.role.slice(1) %>
                    </div>
                  </div>
                </div>
              </li>
              <li><hr class="dropdown-divider"></li>
              <% if (currUser.role === 'admin') { %>
                <li><a class="dropdown-item" href="/admin/dashboard"><i class="fa-solid fa-chart-pie me-2 text-purple"></i>Admin Dashboard</a></li>
              <% } %>
              <% if (currUser.role === 'owner') { %>
                <li><a class="dropdown-item" href="/owner/dashboard"><i class="fa-solid fa-gauge me-2 text-purple"></i>Owner Dashboard</a></li>
              <% } %>
              <% if (currUser.role === 'client') { %>
                <li><a class="dropdown-item" href="/bookings"><i class="fa-solid fa-calendar-check me-2 text-purple"></i>My Bookings</a></li>
              <% } %>
              <li><a class="dropdown-item" href="/notifications"><i class="fa-solid fa-bell me-2 text-purple"></i>Notifications</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item text-danger" href="/logout">
                  <i class="fa-solid fa-right-from-bracket me-2"></i>Log Out
                </a>
              </li>
            </ul>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<script>
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('main-navbar');
    if (nav) {
      nav.classList.toggle('scrolled', window.scrollY > 10);
    }
  });
  document.addEventListener('DOMContentLoaded', () => {
    fetch('/notifications/count')
      .then(r => r.json())
      .then(data => {
        if (data.count > 0) {
          const badge = document.getElementById('notif-badge');
          if (badge) {
            badge.classList.remove('d-none');
            badge.textContent = data.count;
          }
        }
      }).catch(() => {});
  });
</script>
